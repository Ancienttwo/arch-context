#!/usr/bin/env bun
import { spawn } from "node:child_process";
import { dirname, resolve } from "node:path";
import { fileURLToPath } from "node:url";
import { runFastHookEnqueue } from "../src/hook-fast.ts";

const entry = resolve(dirname(fileURLToPath(import.meta.url)), "../src/main.ts");

if (process.argv[2] === "hook" && (process.argv[3] ?? "enqueue") === "enqueue") {
  const result = await runFastHookEnqueue(process.argv.slice(2), process.cwd());
  if (result.handled) {
    process.stdout.write(`${JSON.stringify(result.envelope, null, 2)}\n`);
    process.exit(0);
  }
}

const child = spawn(process.execPath, [entry, ...process.argv.slice(2)], {
  stdio: "inherit",
  env: process.env
});

child.once("exit", (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal);
    return;
  }
  process.exit(code ?? 1);
});

child.once("error", (error) => {
  process.stderr.write(`${error instanceof Error ? error.message : String(error)}\n`);
  process.exit(1);
});
