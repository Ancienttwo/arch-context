        "blob": 0,
        "tree": 0
      },
      "forbiddenMediaTypeCounts": {
        "diff": 0,
        "patch": 0
      }
    },
    "baitHits": {
      "log": 0,
      "trace": 0,
      "queue": 0
    }
  },
  "readback": {
    "command": "node scripts/github-egress-recording-readback.mjs readback --recording docs/verification/fg2-egress-recording.json",
    "allowPendingCommand": "node scripts/github-egress-recording-readback.mjs readback --recording docs/verification/fg2-egress-recording.json --allow-pending"
  }
