# ArchContext production GA readback environment template.
# Copy values into a local, ignored env file before running deploy/scripts/production-ga-readback.mjs.

ARCHCONTEXT_READBACK_ENV=production
ARCHCONTEXT_PRODUCTION_BASE_URL=https://archctx.repoharness.com

# Optional bearer token for deployed ArchContext metadata endpoints.
# ARCHCONTEXT_PRODUCTION_BEARER_TOKEN=

# Evidence for live ChatGPT App Directory listing/readback.
# Use either a directory URL if available or a non-secret local evidence artifact path.
# ARCHCONTEXT_OPENAI_DIRECTORY_URL=
# ARCHCONTEXT_OPENAI_DIRECTORY_EVIDENCE_PATH=

# Evidence for real provider delivery readback.
# Use a real webhook probe only when the destination is safe to receive a test notification.
# ARCHCONTEXT_READBACK_PROVIDER_WEBHOOK_URL=
# ARCHCONTEXT_PROVIDER_DELIVERY_EVIDENCE_PATH=
# ARCHCONTEXT_READBACK_SEND_PROVIDER_PROBE=0

# Output capture path. Commit only sanitized captures that pass privacy audit.
ARCHCONTEXT_READBACK_CAPTURE_PATH=docs/security/captures/production-redacted.har.json
