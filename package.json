{
  "name": "archcontext",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24 <26"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "test:contracts": "bun test packages/contracts/test/contracts.test.ts",
    "readback:ga:preflight": "node deploy/scripts/production-ga-readback.mjs preflight --environment production --json",
    "readback:ga": "node deploy/scripts/production-ga-readback.mjs run --environment production --json",
    "verify": "bun run typecheck && bun test && node scripts/privacy-route-audit.mjs && node scripts/privacy-packet-capture-audit.mjs docs/security/captures/metadata-only.har.json && node scripts/privacy-capture-manifest.mjs readback && node scripts/sprint-status-check.mjs",
    "check:sprint": "node scripts/sprint-status-check.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
