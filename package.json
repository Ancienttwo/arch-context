{
  "name": "archcontext",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/contracts",
    "packages/core",
    "packages/local-runtime",
    "packages/surfaces",
    "packages/cloud"
  ],
  "engines": {
    "node": ">=24 <26"
  },
  "dependencies": {
    "@archcontext/surfaces": "workspace:*",
    "@colbymchenry/codegraph": "1.0.1"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "test:contracts": "bun test packages/contracts/test/contracts.test.ts",
    "e2e:local-product-tarball": "node scripts/local-product-tarball-smoke.mjs",
    "e2e:local-no-cloud": "node scripts/local-no-cloud-e2e.mjs",
    "check:production-mock-reachability": "node scripts/production-mock-reachability-audit.mjs",
    "handoff:s2:external": "node scripts/sprint2-external-evidence-handoff.mjs render",
    "record:s2:external": "node scripts/sprint2-external-evidence-record.mjs record",
    "readback:s2:external": "node scripts/sprint2-external-evidence-readback.mjs readback --json",
    "readback:fg2:egress": "node scripts/github-egress-recording-readback.mjs readback --allow-pending",
    "readback:fg2:staging": "node scripts/fg2-staging-evidence-readback.mjs readback --packet docs/verification/fg2-staging-evidence.json --allow-pending --json",
    "readback:fg2:install-revoke": "node scripts/fg2-install-revoke-readback.mjs run --env-file _ops/env/fg2-staging.env --packet docs/verification/fg2-staging-evidence.json --out docs/verification/fg2-install-revoke-readback.json --confirm-suspend --json",
    "readback:fg3:developer-review": "bun scripts/fg3-developer-review-check-readback.ts run --env-file _ops/env/fg2-staging.env --packet docs/verification/fg2-staging-evidence.json --out docs/verification/fg3-developer-review-check-readback.json --json",
    "readback:fg3:check-supersede": "bun scripts/fg3-check-supersede-readback.ts run --env-file _ops/env/fg2-staging.env --packet docs/verification/fg2-staging-evidence.json --out docs/verification/fg3-check-supersede-readback.json --json",
    "readback:fg3:process-e2e": "bun scripts/fg3-developer-review-process-e2e.ts run --out docs/verification/fg3-developer-review-process-e2e.json --json",
    "readback:fg3:negative-identity": "bun scripts/fg3-negative-identity-matrix.ts run --out docs/verification/fg3-negative-identity-matrix.json --json",
    "readback:fg3:adversarial-conclusion": "bun scripts/fg3-adversarial-review-conclusion.ts run --out docs/verification/fg3-adversarial-review-conclusion.json --json",
    "readback:fg3:attestation-security": "bun scripts/fg3-attestation-security-suite.ts run --out docs/verification/fg3-attestation-security-suite.json --json",
    "readback:fg3:real-pr-synchronize": "bun scripts/fg3-real-pr-synchronize-e2e.ts inspect --evidence docs/verification/fg3-real-pr-synchronize-e2e.json --json",
    "readback:fg3:required-trust": "bun scripts/fg3-required-trust-staging-readback.ts run --env-file _ops/env/fg2-staging.env --packet docs/verification/fg2-staging-evidence.json --out docs/verification/fg3-required-trust-staging-readback.json --json",
    "readback:fg3:cloud-dlp": "bun scripts/fg3-cloud-dlp-readback.ts run --out docs/verification/fg3-cloud-dlp-readback.json --json",
    "readback:fg4:github-hosted": "bun scripts/fg4-github-hosted-runner-readback.ts run --env-file _ops/env/fg2-staging.env --packet docs/verification/fg2-staging-evidence.json --out docs/verification/fg4-github-hosted-runner-readback.json --json",
    "readback:fg4:developer-cannot-satisfy-organization": "bun scripts/fg4-developer-cannot-satisfy-organization-readback.ts run --source docs/verification/fg4-organization-runner-ruleset-readback.json --out docs/verification/fg4-developer-cannot-satisfy-organization-readback.json --json",
    "readback:fg4:key-lifecycle": "bun scripts/fg4-runner-key-lifecycle-e2e.ts run --out docs/verification/fg4-runner-key-lifecycle-e2e.json --json",
    "readback:fg4:supply-chain-negative": "bun scripts/fg4-supply-chain-negative-readback.ts run --out docs/verification/fg4-supply-chain-negative-readback.json --json",
    "readback:fg4:deterministic-conclusion": "bun scripts/fg4-deterministic-conclusion-readback.ts run --out docs/verification/fg4-deterministic-conclusion-readback.json --json",
    "readback:fg4:runner-dlp": "bun scripts/fg4-runner-dlp-readback.ts run --source docs/verification/fg4-github-hosted-runner-readback.json --out docs/verification/fg4-runner-dlp-readback.json --json",
    "readback:fg4:self-hosted": "bun scripts/fg4-self-hosted-runner-readback.ts run --out docs/verification/fg4-self-hosted-runner-readback.json --json",
    "readback:fg4:self-hosted-execution": "bun scripts/fg4-github-hosted-runner-readback.ts run --self-hosted --runner-labels self-hosted,macOS,ARM64,archcontext-fg4-eg2 --env-file _ops/env/fg2-staging.env --packet docs/verification/fg2-staging-evidence.json --out docs/verification/fg4-self-hosted-runner-execution-readback.json --json",
    "readback:fg4:public-fork": "bun scripts/fg4-public-fork-adversarial-readback.ts run --out docs/verification/fg4-public-fork-adversarial-readback.json --json",
    "deploy:fg2:staging:secrets": "node deploy/scripts/fg2-staging-secrets.mjs install --env-file _ops/env/fg2-staging.env --environment staging",
    "deploy:fg2:staging": "wrangler deploy --env staging --config wrangler.jsonc",
    "readback:ga:preflight": "node deploy/scripts/production-ga-readback.mjs preflight --environment production --json",
    "readback:ga": "node deploy/scripts/production-ga-readback.mjs run --environment production --json",
    "verify": "bun run typecheck && node scripts/package-boundary-audit.mjs && node scripts/production-mock-reachability-audit.mjs && bun test && node scripts/packaged-cli-smoke.mjs && node scripts/privacy-route-audit.mjs && bun run verify:github-api-contract && node scripts/privacy-packet-capture-audit.mjs docs/security/captures/metadata-only.har.json && node scripts/privacy-capture-manifest.mjs readback && node scripts/security-scan-manifest.mjs readback && node scripts/verify-acceptance-ledger.mjs && node scripts/sprint-status-check.mjs && bun evals/run.ts --check",
    "verify:acceptance-ledger": "node scripts/verify-acceptance-ledger.mjs",
    "verify:github-api-contract": "bun run verify:privacy-contract",
    "verify:privacy-contract": "node scripts/github-api-contract-audit.mjs",
    "check:sprint": "node scripts/sprint-status-check.mjs",
    "check:package-boundaries": "node scripts/package-boundary-audit.mjs",
    "eval": "bun evals/run.ts"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
