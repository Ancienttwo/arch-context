{
  "compilerOptions": {
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@archcontext/contracts": ["packages/contracts/src/index.ts"],
      "@archcontext/core": ["packages/core/src/index.ts"],
      "@archcontext/core/application": ["packages/core/application/src/index.ts"],
      "@archcontext/core/agent-orchestrator": ["packages/core/agent-orchestrator/src/index.ts"],
      "@archcontext/core/architecture-ledger": ["packages/core/architecture-ledger/src/index.ts"],
      "@archcontext/core/architecture-domain": ["packages/core/architecture-domain/src/index.ts"],
      "@archcontext/core/changeset-engine": ["packages/core/changeset-engine/src/index.ts"],
      "@archcontext/core/context-compiler": ["packages/core/context-compiler/src/index.ts"],
      "@archcontext/core/policy-engine": ["packages/core/policy-engine/src/index.ts"],
      "@archcontext/core/practice-catalog": ["packages/core/practice-catalog/src/index.ts"],
      "@archcontext/core/practice-engine": ["packages/core/practice-engine/src/index.ts"],
      "@archcontext/core/pressure-engine": ["packages/core/pressure-engine/src/index.ts"],
      "@archcontext/core/reconcile-engine": ["packages/core/reconcile-engine/src/index.ts"],
      "@archcontext/core/refactor-decision": ["packages/core/refactor-decision/src/index.ts"],
      "@archcontext/core/retrieval": ["packages/core/retrieval/src/index.ts"],
      "@archcontext/core/review-engine": ["packages/core/review-engine/src/index.ts"],
      "@archcontext/local-runtime": ["packages/local-runtime/src/index.ts"],
      "@archcontext/local-runtime/codegraph-adapter": ["packages/local-runtime/codegraph-adapter/src/index.ts"],
      "@archcontext/local-runtime/context7-adapter": ["packages/local-runtime/context7-adapter/src/index.ts"],
      "@archcontext/local-runtime/git-adapter": ["packages/local-runtime/git-adapter/src/index.ts"],
      "@archcontext/local-runtime/local-store-sqlite": ["packages/local-runtime/local-store-sqlite/src/index.ts"],
      "@archcontext/local-runtime/model-store-yaml": ["packages/local-runtime/model-store-yaml/src/index.ts"],
      "@archcontext/local-runtime/runtime-daemon": ["packages/local-runtime/runtime-daemon/src/index.ts"],
      "@archcontext/local-runtime/test/codegraph-factories": ["packages/local-runtime/codegraph-adapter/test/factories.ts"],
      "@archcontext/local-runtime/test/local-store-factories": ["packages/local-runtime/local-store-sqlite/test/factories.ts"],
      "@archcontext/surfaces": ["packages/surfaces/src/index.ts"],
      "@archcontext/surfaces/adapter-likec4": ["packages/surfaces/adapter-likec4/src/index.ts"],
      "@archcontext/surfaces/adapter-structurizr": ["packages/surfaces/adapter-structurizr/src/index.ts"],
      "@archcontext/surfaces/chatgpt-ui": ["packages/surfaces/chatgpt-ui/src/index.ts"],
      "@archcontext/surfaces/cli": ["packages/surfaces/cli/src/main.ts"],
      "@archcontext/surfaces/explorer-ui": ["packages/surfaces/explorer-ui/src/index.ts"],
      "@archcontext/surfaces/mcp-local": ["packages/surfaces/mcp-local/src/index.ts"],
      "@archcontext/surfaces/renderer": ["packages/surfaces/renderer/src/index.ts"],
      "@archcontext/cloud": ["packages/cloud/src/index.ts"],
      "@archcontext/cloud/attestation": ["packages/cloud/attestation/src/index.ts"],
      "@archcontext/cloud/cloud-db": ["packages/cloud/cloud-db/src/index.ts"],
      "@archcontext/cloud/control-plane": ["packages/cloud/control-plane/src/index.ts"],
      "@archcontext/cloud/control-plane-client": ["packages/cloud/control-plane-client/src/index.ts"],
      "@archcontext/cloud/github-app": ["packages/cloud/github-app/src/index.ts"],
      "@archcontext/cloud/hardening": ["packages/cloud/hardening/src/index.ts"],
      "@archcontext/cloud/mcp-cloud-metadata": ["packages/cloud/mcp-cloud-metadata/src/index.ts"],
      "@archcontext/cloud/notifications": ["packages/cloud/notifications/src/index.ts"],
      "@archcontext/cloud/runner": ["packages/cloud/runner/src/index.ts"]
    },
    "strict": true,
    "target": "ES2024",
    "types": [
      "bun-types",
      "node"
    ]
  },
  "include": [
    "apps/**/*.ts",
    "deploy/**/*.mjs",
    "deploy/**/*.ts",
    "packages/**/*.ts",
    "scripts/**/*.mjs",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**"
  ]
}
