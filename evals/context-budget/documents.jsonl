// Constraint-tagged corpus for §25.3 context constraint recall + irrelevant ratio.
// Retriever under test: retrieval.Fts5BaselineRetriever via runRetrievalEval (shipping
// default; embedding stays default-off per ADR-0033). Each line is a RetrievalDocument
// {id, text, constraintIds}. note is audit metadata. anti.* docs are decoys that share
// surface tokens but are never a correct answer.
{"id":"adr.zero-egress","text":"ArchContext never uploads repository source code diffs symbol bodies or architecture model bodies to any SaaS or cloud endpoint","constraintIds":["constraint.zero-egress"],"note":"core privacy guarantee"}
{"id":"guardrail.explorer-loopback","text":"The architecture explorer binds to the local loopback 127.0.0.1 only is read only requires a short lived token and rejects non GET methods","constraintIds":["constraint.read-only-explorer","constraint.zero-egress"],"note":"explorer guardrail"}
{"id":"adr.embedding-gate","text":"Semantic retrieval embeddings stay disabled by default run on a local vector index only and ship only if they beat the FTS5 baseline under the decision gate","constraintIds":["constraint.embedding-default-off"],"note":"ADR-0033"}
{"id":"guardrail.changeset-approval","text":"Every ChangeSet requires explicit human approval and applies atomically with full rollback when a fault is injected","constraintIds":["constraint.changeset-approval"],"note":"changeset safety"}
{"id":"guardrail.path-allowlist","text":"Writes are confined to the archcontext model policies decisions and generated directories and any path that escapes the repository root is denied","constraintIds":["constraint.path-allowlist"],"note":"path safety"}
{"id":"guardrail.freshness","text":"Review binds to the current HEAD commit and worktree digest and a stale snapshot is rejected before any apply","constraintIds":["constraint.freshness-binding"],"note":"freshness"}
{"id":"adr.codegraph-pin","text":"Code facts come only through the CodeGraph adapter at a pinned exact version and reading the CodeGraph internal SQLite storage is prohibited","constraintIds":["constraint.codegraph-version-pin"],"note":"codegraph boundary"}
{"id":"guardrail.attestation-replay","text":"Signed attestations include a freshness binding so a replayed attestation from an old commit is rejected","constraintIds":["constraint.attestation-replay"],"note":"attestation"}
{"id":"spec.node-support","text":"Supported runtimes are Node 24 LTS as the target and Node 25 as dev compatible and older majors are unsupported","constraintIds":["constraint.node-support"],"note":"runtime matrix"}
{"id":"policy.compat-contract","text":"Any compatibility code path must declare a contract with a kind an owner consumers removal conditions and a review date","constraintIds":["constraint.compat-contract-required"],"note":"compat policy"}
{"id":"spec.target-migration","text":"An intervention separates the durable target state from the temporary migration state and migration only relations never appear in the target state","constraintIds":["constraint.target-migration-separation"],"note":"target vs migration"}
{"id":"spec.telemetry","text":"Telemetry is event level only with no repository content included and the event schema is published openly","constraintIds":["constraint.metadata-only-telemetry"],"note":"telemetry"}
{"id":"spec.local-first","text":"The local runtime initializes indexes queries context and validates deterministically without any SaaS GitHub App or ChatGPT dependency","constraintIds":["constraint.local-first"],"note":"local first"}
{"id":"audit.privacy-route","text":"A privacy route audit proves there is no code content route from the local runtime to the cloud metadata service","constraintIds":["constraint.zero-egress","constraint.metadata-only-telemetry"],"note":"privacy audit"}
{"id":"guardrail.token-expiry","text":"Explorer tokens expire after their configured TTL and can be revoked and expired or revoked tokens are refused","constraintIds":["constraint.read-only-explorer"],"note":"token lifecycle"}
{"id":"spec.changeset-digest","text":"A ChangeSet records the expected hash of each target file and refuses to apply when the on disk hash differs","constraintIds":["constraint.changeset-approval","constraint.freshness-binding"],"note":"changeset digest"}
{"id":"spec.offline-entitlement","text":"A paid entitlement works offline until its offline until timestamp after which it becomes inactive","constraintIds":["constraint.local-first"],"note":"offline entitlement"}
{"id":"spec.attestation-trust","text":"Attestation trust levels label organization attested and developer attested and disclose the customer controlled runner limitation","constraintIds":["constraint.attestation-replay"],"note":"trust level"}
{"id":"anti.saas-source-upload","text":"Forbidden anti pattern uploading private repository content patches symbols or architecture model bodies to a hosted SaaS service","constraintIds":[],"note":"decoy: shares upload/repository/architecture tokens but is the forbidden pattern, never a correct answer"}
{"id":"anti.direct-db","text":"Forbidden anti pattern reading another module database directly across the service boundary instead of calling its published interface","constraintIds":[],"note":"decoy: shares module/boundary/service tokens"}
